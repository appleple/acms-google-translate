{
    "name": "appleple/google-translate",
    "description": "a-blog cms extension.",
    "autoload": {
        "psr-4": {
            "Acms\\Plugins\\GoogleTranslate\\": "src/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/phpcs --standard=phpcs.xml",
        "format": "vendor/bin/phpcbf --standard=phpcs.xml",
        "check:version": "vendor/bin/phpcs --standard=PHPCompatibility --runtime-set testVersion 8.1-8.5 --ignore=./src/vendor/* ./src",
        "post-install-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
        "post-update-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
        "package": "@php scripts/package.php",
        "version:set": "@php scripts/version.php",
        "release:patch": "@php scripts/release.php patch",
        "release:minor": "@php scripts/release.php minor",
        "release:major": "@php scripts/release.php major"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "phpcompatibility/php-compatibility": "^10.0@dev",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1"
    },
    "extra": {
        "acms-plugin-tools": {
            "extras": ["docs"]
        }
    },
    "prefer-stable" : true,
    "config": {
        "platform": {
            "php": "8.5.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpcsstandards/composer-installer": true
        }
    }
}
